{
  "name": "g88",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.11"
  },
  "scripts": {
    "build": "pnpm -r --filter @g88/shared run build && pnpm -r --filter !@g88/shared run build",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test"
  },
  "devDependencies": {
    "typescript": "^5.5.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core"
    ],
    "overrides": {
      "glob@10": "10.5.0",
      "picomatch@4": "4.0.4",
      "ws@8": "8.20.1",
      "webpack@5": "5.104.1",
      "ajv@8": "8.20.0",
      "tmp": "0.2.4",
      "@tootallnate/once": ">=3.0.1",
      "fast-xml-parser": ">=5.7.0"
    }
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.1"
  }
}
