# Copy to .env and fill in values.
# All settings have sane defaults for local Docker dev — only secrets need changing.

# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_USER=g88
POSTGRES_PASSWORD=g88dev
POSTGRES_DB=g88
POSTGRES_PORT=5432

# Used by the backend. Render injects DATABASE_URL in production; locally we
# compose it from the vars above.
DATABASE_URL=postgres://g88:g88dev@localhost:5432/g88

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Backend ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# Generate strong secrets in production: `openssl rand -hex 64`
JWT_SECRET=dev-jwt-secret-change-in-production
JWT_REFRESH_SECRET=dev-jwt-refresh-secret-change-in-production

CORS_ORIGINS=http://localhost:3000

# ── External (leave blank for local dev — features degrade gracefully) ────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
SENDGRID_API_KEY=
AWS_REGION=eu-north-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=g88-uploads-dev
GOOGLE_CLIENT_ID=
