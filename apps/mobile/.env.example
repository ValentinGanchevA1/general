# ─── Mobile build-time environment variables ──────────────────────────────────
# Copy to .env (gitignored) and fill in values, OR export before running Metro.
#
# These are inlined at bundle time by babel-plugin-transform-inline-environment-variables.
# Changes require a Metro cache reset:  pnpm --filter @g88/mobile start:reset
#
# Usage:
#   cp apps/mobile/.env.example apps/mobile/.env
#   # edit .env, then:
#   pnpm --filter @g88/mobile android

# ─── Dev API host ─────────────────────────────────────────────────────────────
# Defaults:
#   Android emulator → 10.0.2.2  (AVD loopback to host machine)
#   iOS simulator    → localhost
#   Android USB      → localhost  (requires: adb reverse tcp:3001 tcp:3001)
#   Android Wi-Fi    → set to your machine's LAN IP (e.g. 192.168.1.42)
# API_HOST=192.168.1.42

# ─── Google Sign-In ───────────────────────────────────────────────────────────
# OAuth 2.0 Web Client ID from Google Cloud Console.
# Must match the GOOGLE_CLIENT_ID env var on the backend.
# GOOGLE_WEB_CLIENT_ID=1234567890-xxxx.apps.googleusercontent.com

# ─── Sentry (optional) ────────────────────────────────────────────────────────
# Public DSN from your Sentry React Native project. Leave empty to disable.
# SENTRY_DSN=https://xxxx@oXXXXX.ingest.sentry.io/XXXXXXX
